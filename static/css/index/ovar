/* ===== Overlay Menu - NEW DESIGN ===== */
.menu-overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: #FFFFFF;
    z-index: 2000;
    overflow-y: auto;
}

/* الشريط العلوي */
.overlay-top-bar {
    padding: 15px 0;
    border-bottom: 1px solid #eaeaea;
}

.overlay-logo {
    height: 40px;
    width: auto;
}

.overlay-language {
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    padding: 8px 12px;
    border-radius: 4px;
    transition: background-color 0.3s ease;
}

.overlay-language:hover {
    background-color: #f5f5f5;
}

.overlay-flag-text {
    font-family: 'Raleway', sans-serif;
    font-size: 16px;
    font-weight: 600;
    color: #052946;
}

.overlay-dropdown-arrow svg {
    transition: transform 0.3s ease;
}

.overlay-language:hover .overlay-dropdown-arrow svg {
    transform: rotate(180deg);
}

.overlay-top-links {
    display: flex;
    gap: 30px;
    justify-content: center;
}

.overlay-top-link {
    font-family: 'Raleway', sans-serif;
    font-size: 16px;
    font-weight: 500;
    color: #052946;
    text-decoration: none;
    padding: 8px 0;
    position: relative;
    transition: color 0.3s ease;
}

.overlay-top-link:hover {
    color: #7F1726;
}

.overlay-top-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: #7F1726;
    transition: width 0.3s ease;
}

.overlay-top-link:hover::after {
    width: 100%;
}

.overlay-account-icon {
    background: transparent !important;
    width: auto !important;
    height: auto !important;
    border-radius: 0 !important;
    padding: 0 !important;
}
.overlay-profile-icon {
    width: 30px !important;
    height: 30px !important;
}
.overlay-profile-icon {
    transition: all 0.3s ease;
}

.overlay-account-icon:hover .overlay-profile-icon {
    transform: translateY(-3px) scale(1.15);
}
.overlay-account-icon {
    cursor: pointer;
}

.overlay-account-icon:hover {
    background: #e8e8e8;
}

.overlay-profile-icon {
    width: 22px;
    height: 22px;
    fill: #052946;
}

.overlay-close-btn {
    background: none;
    border: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background-color 0.3s ease;
}

.overlay-close-btn:hover {
    background-color: #f5f5f5;
}

/* القائمة الرئيسية */
.overlay-main-nav {
    padding: 20px 0;
    border-bottom: 1px solid #eaeaea;
}

.overlay-nav-items {
    display: flex;
    justify-content: center;
    gap: 40px;
}

.overlay-nav-item {
    background: none;
    border: none;
    font-family: 'Raleway', sans-serif;
    font-size: 20px;
    font-weight: 600;
    color: #052946;
    padding: 10px 20px;
    cursor: pointer;
    position: relative;
    transition: color 0.3s ease;
}

.overlay-nav-item:hover,
.overlay-nav-item.active {
    color: #7F1726;
}

.overlay-nav-item::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 3px;
    background: #7F1726;
    transition: width 0.3s ease;
}

.overlay-nav-item:hover::after,
.overlay-nav-item.active::after {
    width: 100%;
}

/* شريط البحث */
.overlay-search-section {
    padding: 25px 0;
    border-bottom: 1px solid #eaeaea;
}

.overlay-search-box {
    position: relative;
    max-width: 800px !important;
    width: 90% !important;
    margin: 0 auto;
}

.overlay-search-input {
    width: 100% !important;
    padding: 15px 20px 15px 50px;
    border: 2px solid #eaeaea;
    border-radius: 30px;
    font-family: 'Raleway', sans-serif;
    font-size: 16px;
    color: #052946;
    background: #FFFFFF;
    outline: none;
    transition: border-color 0.3s ease;
}

.overlay-search-input:focus {
    border-color: #7F1726;
}

.search-icon-overlay {
    position: absolute;
    left: 20px;
    top: 50%;
    transform: translateY(-50%);
    color: #052946;
}

/* محتوى القائمة */
.overlay-content-section {
    padding: 40px 0;
}

.overlay-content {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
    max-width: 1200px;
    margin: 0 auto;
}

.overlay-menu-column {
    display: flex;
    flex-direction: column;
}

.overlay-column-title {
    font-family: 'Raleway', sans-serif;
    font-weight: 600;
    font-size: 18px;
    color: #052946;
    margin-bottom: 15px;
    padding-bottom: 10px;
    border-bottom: 2px solid #052946;
}

.overlay-column-subtitle {
    font-family: 'Raleway', sans-serif;
    font-weight: 400;
    font-size: 14px;
    color: #666666;
    margin-bottom: 20px;
    line-height: 1.5;
}

.overlay-menu-links {
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.overlay-menu-link {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    padding: 8px 0;
    transition: all 0.3s ease;
}

.link-dot {
    width: 6px;
    height: 6px;
    background: #052946;
    border-radius: 50%;
    opacity: 0;
    transition: all 0.3s ease;
}

.link-text {
    font-family: 'Raleway', sans-serif;
    font-weight: 500;
    font-size: 16px;
    color: #052946;
    transition: color 0.3s ease;
}

.overlay-menu-link:hover .link-dot {
    opacity: 1;
    transform: scale(1.2);
}

.overlay-menu-link:hover .link-text {
    color: #7F1726;
    padding-left: 5px;
}

/* ===== زيادة حجم وتباعد عناصر القائمة في Overlay ===== */
.overlay-nav-items {
    display: flex;
    justify-content: center;
    gap: 60px !important;
}

.overlay-nav-item {
    background: none;
    border: none;
    font-family: 'Raleway', sans-serif;
    font-size: 22px !important;
    font-weight: 700 !important;
    color: #052946;
    padding: 12px 24px !important;
    cursor: pointer;
    position: relative;
    transition: all 0.3s ease;
    letter-spacing: 0.5px;
}

.overlay-nav-item:hover,
.overlay-nav-item.active {
    color: #7F1726;
    transform: translateY(-2px);
}

.overlay-nav-item::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 4px;
    background: #7F1726;
    transition: width 0.3s ease;
}

.overlay-nav-item:hover::after,
.overlay-nav-item.active::after {
    width: 100%;
}

/* ===== تعديلات الـ Overlay Menu - زيادة التباعد وتكبير الخط ===== */
@media (min-width: 992px) {
