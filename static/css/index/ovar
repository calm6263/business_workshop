        padding: 18px 20px 18px 50px !important; /* زيادة padding */
        font-size: 18.4px !important; /* زيادة حجم الخط */
    }
    
    /* تكبير أيقونة البحث */
    .index-page #menuOverlay .search-icon-overlay {
        left: 25px;
    }
    
    .index-page #menuOverlay .search-icon-overlay svg {
