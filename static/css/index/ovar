        margin-top: 40px !important;
        padding-top: 20px !important;
    }
    
    /* زيادة حجم الخط في المحتوى بنسبة 15% */
    .index-page #menuOverlay .overlay-column-title {
        font-size: 18.4px !important; /* 16px + 15% */
    }
    
    .index-page #menuOverlay .link-text {
        font-size: 16.1px !important; /* 14px + 15% */
    }
    
    .index-page #menuOverlay .overlay-column-subtitle {
        font-size: 13.8px !important; /* 12px + 15% */
    }
    
    /* تكبير شريط البحث */
