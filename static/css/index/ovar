}

/* ===== إصلاحات للقوائم المنسدلة في Overlay Menu ===== */

/* تأكد من أن القوائم المنسدلة تظهر فوق الـ Overlay */
.language-dropdown,
.account-dropdown {
    z-index: 2100 !important;
}

/* حاوية اللغة في الـ Overlay */
.overlay-language-container {
    position: relative;
}

/* سهم اللغة في الـ Overlay */
.overlay-language .overlay-dropdown-arrow {
    transition: transform 0.3s ease;
}

.overlay-language.active .overlay-dropdown-arrow svg {
    transform: rotate(180deg);
}

/* أيقونة الحساب في الـ Overlay */
.overlay-account-container {
    position: relative;
}

/* إصلاح لعرض القوائم المنسدلة في الـ Overlay */
.menu-overlay .language-dropdown,
.menu-overlay .account-dropdown {
    position: absolute !important;
    top: 100% !important;
    margin-top: 5px !important;
    display: none !important;
    z-index: 2100 !important;
}

.menu-overlay .language-dropdown.active,
.menu-overlay .account-dropdown.active {
    display: block !important;
    animation: fadeIn 0.3s ease !important;
}

/* تعديل موقع قائمة اللغات في الـ Overlay */
.menu-overlay .language-dropdown {
    left: 0 !important;
    right: auto !important;
    width: 180px !important;
}

/* تعديل موقع قائمة الحساب في الـ Overlay */
.menu-overlay .account-dropdown {
    left: auto !important;
    right: 0 !important;
    width: 280px !important;
}

