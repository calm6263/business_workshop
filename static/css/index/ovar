/* تحسينات للاستجابة */
@media (max-width: 1200px) {
    .overlay-content {
        grid-template-columns: repeat(2, 1fr);
        gap: 30px;
    }
}

@media (max-width: 992px) {
    .menu-overlay {
        display: none !important;
    }
}

@media (max-width: 768px) {
    .overlay-content {
        grid-template-columns: 1fr;
        gap: 30px;
    }
    
    .overlay-top-links {
        gap: 20px;
    }
    
    .overlay-nav-items {
        gap: 20px;
    }
    
